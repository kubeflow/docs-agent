FROM python:3.11-slim

# Install python packages without caching to keep image size small.
# Embeddings are generated by the in-cluster TEI service now (see utils.py),
# so no ML model needs to be loaded or baked into this image anymore.
RUN pip install --no-cache-dir \
    kfp>=2.0.0 \
    pymilvus>=2.4.0 \
    langchain-text-splitters \
    beautifulsoup4 \
    requests
